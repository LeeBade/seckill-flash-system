<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
        异步日志配置——防止压测时 Console I/O 锁竞争拖垮业务线程
        设计原则:
          1. INFO/DEBUG 走异步队列, 不阻塞业务线程
          2. WARN/ERROR 走同步 Appender, 保证异常日志不丢失
          3. 队列 80% 满时丢弃 INFO/DEBUG, 保全业务吞吐
    -->

    <!-- ========== 基础属性 ========== -->
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- ========== 同步 Appender: WARN + ERROR（绝不丢弃）========== -->
    <appender name="CONSOLE_WARN" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ========== 子 Appender: INFO 同步输出（给 AsyncAppender 包裹）========== -->
    <appender name="CONSOLE_INFO_SYNC" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>INFO</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ========== 子 Appender: DEBUG 同步输出（给 AsyncAppender 包裹）========== -->
    <appender name="CONSOLE_DEBUG_SYNC" class="ch.qos.logback.core.ConsoleAppender">
        <filter class="ch.qos.logback.classic.filter.LevelFilter">
            <level>DEBUG</level>
            <onMatch>ACCEPT</onMatch>
            <onMismatch>DENY</onMismatch>
        </filter>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
        </encoder>
    </appender>

    <!-- ========== 异步 Appender: INFO（可丢弃，引用 CONSOLE_INFO_SYNC）========== -->
    <appender name="ASYNC_INFO" class="ch.qos.logback.classic.AsyncAppender">
        <queueSize>1024</queueSize>
        <discardingThreshold>819</discardingThreshold>
        <neverBlock>true</neverBlock>
        <appender-ref ref="CONSOLE_INFO_SYNC"/>
    </appender>

    <!-- ========== 异步 Appender: DEBUG（压测时关闭）========== -->
    <springProfile name="default">
        <appender name="ASYNC_DEBUG" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>512</queueSize>
            <discardingThreshold>409</discardingThreshold>
            <neverBlock>true</neverBlock>
            <appender-ref ref="CONSOLE_DEBUG_SYNC"/>
        </appender>
    </springProfile>

    <!-- ========== 生产环境：落盘文件（异步）========== -->
    <springProfile name="prod">
        <appender name="FILE_SYNC" class="ch.qos.logback.core.rolling.RollingFileAppender">
            <file>logs/seckill.log</file>
            <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
                <fileNamePattern>logs/seckill.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
                <maxFileSize>100MB</maxFileSize>
                <maxHistory>7</maxHistory>
                <totalSizeCap>1GB</totalSizeCap>
            </rollingPolicy>
            <encoder>
                <pattern>${LOG_PATTERN}</pattern>
            </encoder>
        </appender>

        <appender name="ASYNC_FILE" class="ch.qos.logback.classic.AsyncAppender">
            <queueSize>1024</queueSize>
            <discardingThreshold>819</discardingThreshold>
            <neverBlock>true</neverBlock>
            <appender-ref ref="FILE_SYNC"/>
        </appender>

        <root level="INFO">
            <!-- 生产只留 WARN+ 到控制台（运维告警），INFO+ 走文件 -->
            <appender-ref ref="CONSOLE_WARN"/>
            <appender-ref ref="ASYNC_FILE"/>
        </root>
    </springProfile>

    <!-- ========== 非生产环境 Root Logger（dev / test / default）========== -->
    <springProfile name="!prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE_WARN"/>
            <appender-ref ref="ASYNC_INFO"/>
        </root>
    </springProfile>

    <!-- ========== 第三方框架日志压制 ========== -->
    <logger name="com.seckill" level="INFO"/>
    <logger name="org.apache.rocketmq" level="INFO"/>
    <logger name="io.lettuce" level="WARN"/>
    <logger name="org.redisson" level="WARN"/>
    <logger name="com.zaxxer.hikari" level="WARN"/>
    <logger name="org.springframework" level="WARN"/>
    <logger name="io.undertow" level="WARN"/>

</configuration>
